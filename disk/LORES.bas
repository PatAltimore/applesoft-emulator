10 REM LORES GRAPHICS DEMO
20 REM SCENE 1: 4x4 COLOR GRID - ALL 16 COLORS
30 GR
40 FOR C = 0 TO 15
50 COLOR= C
60 X1 = (C - INT(C / 4) * 4) * 10
70 Y1 = INT(C / 4) * 10
80 FOR DY = 0 TO 9
90 HLIN X1, X1 + 9 AT Y1 + DY
100 NEXT DY
110 NEXT C
120 VTAB 22
130 PRINT "ALL 16 LORES COLORS - PRESS A KEY"
140 GET K$
150 REM SCENE 2: CONCENTRIC RECTANGLES
160 GR
170 FOR I = 0 TO 9
180 COLOR= I + 5
190 HLIN I, 39 - I AT I
200 HLIN I, 39 - I AT 39 - I
210 VLIN I + 1, 38 - I AT I
220 VLIN I + 1, 38 - I AT 39 - I
230 NEXT I
240 VTAB 22
250 PRINT "CONCENTRIC RECTANGLES - PRESS A KEY"
260 GET K$
270 REM SCENE 3: VERTICAL RAINBOW STRIPES
280 GR
290 FOR C = 0 TO 15
300 COLOR= C
310 X1 = INT(C * 5 / 2)
320 X2 = INT((C + 1) * 5 / 2) - 1
330 FOR X = X1 TO X2
340 VLIN 0, 39 AT X
350 NEXT X
360 NEXT C
370 VTAB 22
380 PRINT "RAINBOW STRIPES - PRESS A KEY"
390 GET K$
400 TEXT
410 PRINT "LORES DEMO COMPLETE!"
