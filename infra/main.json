{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "17571505789715993730"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "Name of the azd environment used to make resource names unique."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all provisioned resources."
      }
    },
    "staticWebAppLocation": {
      "type": "string",
      "defaultValue": "westus2",
      "metadata": {
        "description": "Azure region for the Static Web App frontend."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to all resources."
      }
    }
  },
  "variables": {
    "resourceToken": "[toLower(uniqueString(subscription().subscriptionId, resourceGroup().id, parameters('environmentName')))]",
    "staticWebAppName": "[take(format('swa-{0}-{1}', parameters('environmentName'), variables('resourceToken')), 40)]",
    "baseTags": "[union(parameters('tags'), createObject('azd-env-name', parameters('environmentName')))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2025-03-01",
      "name": "[variables('staticWebAppName')]",
      "location": "[parameters('staticWebAppLocation')]",
      "tags": "[union(variables('baseTags'), createObject('azd-service-name', 'web'))]",
      "sku": {
        "name": "Free",
        "tier": "Free"
      },
      "properties": {
        "allowConfigFileUpdates": true,
        "publicNetworkAccess": "Enabled",
        "stagingEnvironmentPolicy": "Disabled"
      }
    }
  ],
  "outputs": {
    "SERVICE_WEB_NAME": {
      "type": "string",
      "value": "[variables('staticWebAppName')]"
    },
    "SERVICE_WEB_ENDPOINT_URL": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname)]"
    },
    "AZURE_LOCATION": {
      "type": "string",
      "value": "[parameters('location')]"
    }
  }
}