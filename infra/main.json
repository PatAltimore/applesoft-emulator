{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "4917908115876324622"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "Name of the azd environment used to make resource names unique."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all provisioned resources."
      }
    },
    "staticWebAppLocation": {
      "type": "string",
      "defaultValue": "westus2",
      "metadata": {
        "description": "Azure region for the Static Web App frontend."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to all resources."
      }
    }
  },
  "variables": {
    "resourceToken": "[toLower(uniqueString(subscription().subscriptionId, resourceGroup().id, parameters('environmentName')))]",
    "planName": "[take(format('asp-{0}-{1}', parameters('environmentName'), variables('resourceToken')), 40)]",
    "webAppName": "[take(format('app-{0}-{1}', parameters('environmentName'), variables('resourceToken')), 60)]",
    "staticWebAppName": "[take(format('swa-{0}-{1}', parameters('environmentName'), variables('resourceToken')), 40)]",
    "baseTags": "[union(parameters('tags'), createObject('azd-env-name', parameters('environmentName')))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2025-03-01",
      "name": "[variables('staticWebAppName')]",
      "location": "[parameters('staticWebAppLocation')]",
      "tags": "[union(variables('baseTags'), createObject('azd-service-name', 'web'))]",
      "sku": {
        "name": "Free",
        "tier": "Free"
      },
      "properties": {
        "allowConfigFileUpdates": true,
        "publicNetworkAccess": "Enabled",
        "stagingEnvironmentPolicy": "Disabled"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "tags": "[variables('baseTags')]",
      "sku": {
        "name": "B1",
        "tier": "Basic",
        "size": "B1",
        "capacity": 1
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "tags": "[union(variables('baseTags'), createObject('azd-service-name', 'api'))]",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|8.0",
          "alwaysOn": true,
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "appSettings": [
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "Cors__AllowedOrigins__0",
              "value": "http://localhost:4280"
            },
            {
              "name": "Cors__AllowedOrigins__1",
              "value": "http://127.0.0.1:4280"
            },
            {
              "name": "Cors__AllowedOrigins__2",
              "value": "http://localhost:5500"
            },
            {
              "name": "Cors__AllowedOrigins__3",
              "value": "http://127.0.0.1:5500"
            },
            {
              "name": "Cors__AllowedOrigins__4",
              "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname)]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.Web/staticSites', variables('staticWebAppName'))]"
      ]
    }
  ],
  "outputs": {
    "SERVICE_API_NAME": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "SERVICE_API_ENDPOINT_URL": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01').defaultHostName)]"
    },
    "SERVICE_WEB_NAME": {
      "type": "string",
      "value": "[variables('staticWebAppName')]"
    },
    "SERVICE_WEB_ENDPOINT_URL": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname)]"
    },
    "AZURE_LOCATION": {
      "type": "string",
      "value": "[parameters('location')]"
    }
  }
}