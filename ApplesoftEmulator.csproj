<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UserSecretsId>a49eec04-cfc4-454c-915a-a527ede2487a</UserSecretsId>
  </PropertyGroup>

  <!-- Copy disk folder contents to build output so LOAD/CATALOG work from any platform -->
  <ItemGroup>
    <None Include="disk\**" CopyToOutputDirectory="PreserveNewest" LinkBase="disk" />
  </ItemGroup>

</Project>
